generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model MembershipRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  location  String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
}

model PrayerRequest {
  id             String   @id @default(cuid())
  name           String?
  email          String?
  request        String
  isConfidential Boolean  @default(true)
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
}

model Teaching {
  id         String  @id @default(cuid())
  slug       String  @unique
  title      String
  content_en String?
  content_zu String?
  content_st String?
  pdf_url_en String?
  pdf_url_zu String?
  pdf_url_st String?
}

model OfferingTransaction {
  id         String   @id @default(cuid())
  reference  String   @unique
  email      String
  amount     Int
  currency   String
  status     String
  provider   String   @default("paystack")
  paidAt     DateTime?
  createdAt  DateTime @default(now())
}
